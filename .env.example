# Скопируйте в backend/.env
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5435/nerd_db
SECRET_KEY=change-me-in-production
KAFKA_URL=localhost:9092
ML_SERVICE_URL=http://localhost:8091
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_SERVICE_URL=http://127.0.0.1:8001

# S3 / MinIO (пустой bucket = локальные файлы в backend/storage/uploads)
# MinIO: docker compose --profile storage up → http://localhost:9001
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL_PREFIX=
S3_PREFIX=uploads
