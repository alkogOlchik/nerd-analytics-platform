DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5436/nerd_db
# Витрина для /analytics (обязательно после alembic -c analytics_alembic.ini + build_analytics_warehouse)
ANALYTICS_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5436/nerd_analytics_db
SECRET_KEY=change-me-in-production
KAFKA_URL=localhost:9092
ML_SERVICE_URL=http://127.0.0.1:8091
OLLAMA_BASE_URL=http://127.0.0.1:11434
ML_OLLAMA_FALLBACK=true
# Если включён системный прокси (Clash/VPN на 127.0.0.1:10809), добавьте в переменные среды Windows:
# NO_PROXY=127.0.0.1,localhost
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_SERVICE_URL=http://127.0.0.1:8001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8001/auth/oauth/callback

# Файлы в чате и тикетах (без S3 — локально в LOCAL_UPLOAD_DIR, URL /files/local/…)
# MinIO локально: docker run -p 9000:9000 -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin minio/minio server /data
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL_PREFIX=
S3_PREFIX=uploads
LOCAL_UPLOAD_DIR=backend/storage/uploads
FILE_UPLOAD_MAX_BYTES=10485760

# Регистрация админа: POST /auth/admin/register (после bootstrap — секрет обязателен)
ADMIN_REGISTRATION_SECRET=
